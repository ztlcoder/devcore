{
    "version": "11.0.1",
    "description": "A fast and disk space efficient Node package manager.",
    "homepage": "https://pnpm.io/",
    "license": "MIT",
    "architecture":
    {
        "64bit":
        {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.0.1/pnpm-win32-x64.zip",
            "hash": "08f1301a2fe9d089ca0e5c31c4377d52316b38a09434dec443e656883de254af"
        },
        "arm64":
        {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.0.1/pnpm-win32-arm64.zip",
            "hash": "d945324b6a81ecca8d9813be66bc5c4039756edb8a452b70615fd568452c6b56"
        }
    },
    "env_set":
    {
        "PNPM_HOME": "$persist_dir",
        "pnpm_config_registry": "https://registry.npmmirror.com/",
        "pnpm_config_store_dir": "$persist_dir/store",
        "pnpm_config_cache_dir": "$persist_dir/cache",
        "pnpm_config_state_dir": "$persist_dir/state"
    },
    "env_add_path": "bin",
    "bin":
    [
        "pnpm.exe",
        [
            "pnpm.exe",
            "pnpx",
            "dlx"
        ]
    ],
    "persist":
    [
        "config",
        "store",
        "bin",
        "cache",
        "state"
    ],
    "post_install":
    [
        "if (!(Test-Path \"$persist_dir\\bin\")) { New-Item -ItemType Directory -Path \"$persist_dir\\bin\" -Force | Out-Null }"
    ],
    "checkver":
    {
        "github": "https://github.com/pnpm/pnpm"
    },
    "autoupdate":
    {
        "architecture":
        {
            "64bit":
            {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-x64.zip"
            },
            "arm64":
            {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-arm64.zip"
            }
        }
    }
}