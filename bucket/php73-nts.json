{
    "version": "7.3.33",
    "description": "PHP 7.3 NTS (Legacy VC15 build) for personal bucket.",
    "homepage": "https://windows.php.net",
    "license": "PHP-3.01",
    "architecture": {
        "64bit": {
            "url": "https://windows.php.net/downloads/releases/archives/php-7.3.33-nts-Win32-VC15-x64.zip",
            "hash": "5EAF3CAD80E678623F222A42C99BCEFCC60EEA359D407FB51E805AFDB3B13E5E"
        }
    },
    "env_set": {
        "PHPRC": "$dir\\cli",
        "PHP_INI_SCAN_DIR": "$dir\\cli\\conf.d;$persist_dir\\conf.d"
    },
    "bin": ["php.exe", "php-cgi.exe"],
    "persist": ["cli"],
    "pre_install": [
        "if (!(Test-Path \"$dir\\cli\")) { New-Item -Type directory \"$dir\\cli\" | Out-Null }",
        "if (!(Test-Path \"$dir\\cli\\php.ini\")) { Copy-Item \"$dir\\php.ini-development\" \"$dir\\cli\\php.ini\" }",
        "if (!(Test-Path \"$dir\\cli\\conf.d\")) { New-Item -Type directory \"$dir\\cli\\conf.d\" | Out-Null }"
    ],
    "post_install": [
        "$ini = \"$dir\\cli\\php.ini\"",
        "(Get-Content $ini) -replace ';extension_dir = \"ext\"', 'extension_dir = \"ext\"' | Set-Content $ini"
    ],
    "checkver": {
        "url": "https://windows.php.net/downloads/releases/archives/",
        "re": "php-(7\\.3\\.[\\d.]+)-nts-Win32-VC15-x64\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://windows.php.net/downloads/releases/archives/php-$version-nts-Win32-VC15-x64.zip"
            }
        },
        "hash": {
            "url": "https://windows.php.net/downloads/releases/archives/sha256sum.txt"
        }
    }
}