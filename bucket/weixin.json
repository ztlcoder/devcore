{
    "version": "4.1.8.107",
    "description": "官方微信",
    "homepage": "https://pc.weixin.qq.com/",
    "architecture": {
        "64bit": {
            "url": "https://dldir1.qq.com/weixin/Windows/WeChatSetup.exe#/dl.7z",
            "hash": "C29FC05630CFC95EF6483F6B5B52AABFE74265BB260E210E78AE437D305D8990"
        }
    },
    "installer": {
        "script": [
            "# 1. 动态获取 Scoop 安装的 7z 绝对路径",
            "$sevenZip = (Get-Command '7z.exe' -ErrorAction SilentlyContinue).Source",
            "if (!$sevenZip) { $sevenZip = \"$env:USERPROFILE\\scoop\\apps\\7zip\\current\\7z.exe\" }",
            "",
            "# 2. 执行二级解压",
            "if (Test-Path \"$dir\\install.7z\") {",
            "    Write-Host \"检测到嵌套包，正在调用 7z 提取...\" -ForegroundColor Cyan",
            "    & \"$sevenZip\" x \"$dir\\install.7z\" \"-o$dir\" -y -aoa | Out-Null",
            "    Remove-Item \"$dir\\install.7z\" -Force",
            "}",
            "",
            "# 3. 提取版本号子目录下的核心文件",
            "$versionSubDir = Get-ChildItem \"$dir\" -Directory | Where-Object { $_.Name -match '^\\d+\\.' } | Select-Object -First 1",
            "if ($versionSubDir) {",
            "    Get-ChildItem \"$($versionSubDir.FullName)\\*\" | Move-Item -Destination \"$dir\" -Force -ErrorAction SilentlyContinue",
            "    Remove-Item $versionSubDir.FullName -Force -Recurse",
            "}",
            "",
            "# 4. 清理残留与注入注册表 (同前)",
            "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Force -Recurse -ErrorAction SilentlyContinue",
            "$reg_path = \"HKCU:Software\\Tencent\\Wexin\"",
            "if (!(Test-Path $reg_path)) { New-Item -Path $reg_path -Type Directory -Force | Out-Null }",
            "New-ItemProperty -Path $reg_path -Name \"InstallPath\" -Value \"$dir\" -Force | Out-Null",
            "New-ItemProperty -Path $reg_path -Name \"FileSavePath\" -Value \"$persist_dir\" -Force | Out-Null"
        ]
    },
    "uninstaller": {
        "script": [
            "$paths = @(\"Tencent\\xwechat\", \"Tencent\\xwechat-updater\")",
            "foreach ($path in $paths) {",
            "    $target = \"$env:APPDATA\\$path\"",
            "    if (Test-Path $target) {",
            "        $item = Get-Item $target",
            "        if ($item.Attributes -match 'ReparsePoint') { $item.Delete() }",
            "        Remove-Item $target -Force -Recurse -ErrorAction SilentlyContinue",
            "    }",
            "}",
            "Remove-ItemProperty -Path \"HKCU:Software\\Tencent\\Wexin\" -Name \"FileSavePath\" -Force -ErrorAction SilentlyContinue"
        ]
    },
    "bin": "Weixin.exe",
    "shortcuts": [
        ["Weixin.exe", "微信"]
    ],
    "persist": "xwechat_files",
    "checkver": {
        "url": "https://pc.weixin.qq.com",
        "re": "version\\s+([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dldir1.qq.com/weixin/Windows/WeChatSetup.exe#/dl.7z"
            }
        }
    }
}