{
    "version": "4.1.8.107",
    "description": "官方微信",
    "homepage": "https://pc.weixin.qq.com/",
    "architecture": {
        "64bit": {
            "url": "https://dldir1.qq.com/weixin/Windows/WeChatSetup.exe#/dl.7z",
            "hash": "b79aa3fdfd208d64f38fcc354684f9af213c05993c6f603521f2813930362b90"
        }
    },
    "installer": {
        "script": [
            "if (Test-Path \"$dir\\install.7z\") {",
            "    # 使用 7zip 静默解压到当前目录",
            "    Invoke-ExternalCommand 7z x \"$dir\\install.7z\" \"-o$dir\" -y | Out-Null",
            "    Remove-Item \"$dir\\install.7z\" -Force",
            "}",
            "# 清理安装包自带的多余文件夹",
            "if (Test-Path \"$dir\\`$PLUGINSDIR\") { Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse }",
            "if (Test-Path \"$dir\\Uninstall.exe\") { Remove-Item \"$dir\\Uninstall.exe\" -Force }",
            "",
            "# 建立配置目录软链接 (Roaming Double-Protection)",
            "$target = \"$env:APPDATA\\Tencent\\xwechat\"",
            "$persist_cfg = \"$persist_dir\\roaming_cfg\"",
            "if (!(Test-Path $persist_cfg)) { New-Item $persist_cfg -ItemType Directory -Force | Out-Null }",
            "if (Test-Path $target) {",
            "    $item = Get-Item $target",
            "    if ($item.Attributes -match 'ReparsePoint') { $item.Delete() } else { Remove-Item $target -Recurse -Force }",
            "}",
            "if (!(Test-Path (Split-Path $target))) { New-Item (Split-Path $target) -ItemType Directory -Force | Out-Null }",
            "New-Item -ItemType Junction -Path $target -Target $persist_cfg | Out-Null",
            "",
            "# 注入路径配置",
            "$config_ini = \"$target\\config\\51a1fffea11325a1e4104c6b3de47af7.ini\"",
            "ensure (Split-Path $config_ini) | Out-Null",
            "Set-Content -NoNewline -Path $config_ini -Value \"$persist_dir\"",
            "$reg_path = \"HKCU:Software\\Tencent\\Wexin\"",
            "if (!(Test-Path \"$reg_path\")) { New-Item -Path \"$reg_path\" -Type Directory -Force | Out-Null }",
            "New-ItemProperty -Path $reg_path -Name \"FileSavePath\" -Value \"$persist_dir\" -Force | Out-Null",
            "New-Item -Path $reg_path -Name \"InstallPath\" -Value \"$dir\" -Force -ErrorAction SilentlyContinue | Out-Null"
        ]
    },
    "uninstaller": {
        "script": [
            "$paths = @(\"Tencent\\xwechat\", \"Tencent\\xwechat-updater\")",
            "foreach ($path in $paths) {",
            "    $target = \"$env:APPDATA\\$path\"",
            "    if (Test-Path $target) {",
            "        $item = Get-Item $target",
            "        if ($item.Attributes -match 'ReparsePoint') { $item.Delete() }",
            "        Remove-Item $target -Force -Recurse -ErrorAction SilentlyContinue",
            "    }",
            "}",
            "Remove-ItemProperty -Path \"HKCU:Software\\Tencent\\Wexin\" -Name \"FileSavePath\" -Force -ErrorAction SilentlyContinue"
        ]
    },
    "bin": "Weixin.exe",
    "shortcuts": [
        [
            "Weixin.exe",
            "微信"
        ]
    ],
    "persist": "xwechat_files",
    "checkver": {
        "url": "https://pc.weixin.qq.com",
        "re": "version\\s+([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dldir1.qq.com/weixin/Windows/WeChatSetup.exe#/dl.7z"
            }
        }
    }
}