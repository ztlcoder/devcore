{
  "version": "8.2.30",
  "description": "A popular general-purpose scripting language that is especially suited to web development. (non-thread safe)",
  "homepage": "https://www.php.net/",
  "license": "PHP-3.01",
  "suggest": {
    "vcredist": "extras/vcredist2022"
  },
  "architecture": {
    "64bit": {
      "url": "https://downloads.php.net/~windows/releases/archives/php-8.2.30-nts-Win32-vs16-x64.zip",
      "hash": "8a6e409adb5f7fb196c07315c69195c4eb87eec8acae2e74a0e04ec50745a055"
    },
    "32bit": {
      "url": "https://downloads.php.net/~windows/releases/archives/php-8.2.30-nts-Win32-vs16-x86.zip",
      "hash": "6f00e490c4cad59f0ebe2f6891208e0630a14af54e81070b20480ecc5f67912b"
    }
  },
  "pre_install": [
    "if (!(Test-Path \"$dir\\cli\\conf.d\")) { (New-Item -Type directory \"$dir\\cli\\conf.d\") | Out-Null }",
    "if (!(Test-Path \"$dir\\php.ini\")) { Copy-Item \"$dir\\php.ini-development\" \"$dir\\php.ini\" }"
  ],
  "post_install": [
    "(Get-Content \"$dir\\php.ini\") | % { $_ -replace ';\\s?(extension_dir = \"ext\")', '$1' } | Set-Content \"$dir\\php.ini\""
  ],
  "bin": [
    "php.exe",
    "php-cgi.exe",
    "phpdbg.exe"
  ],
  "env_set": {
    "PHP_INI_SCAN_DIR": "$persist_dir\\cli;$persist_dir\\cli\\conf.d"
  },
  "persist": [
    "cli",
    "php.ini"
  ],
  "checkver": {
    "url": "https://www.php.net/releases/branches.php",
    "jsonpath": "$..[?(@.version == '8.2')].latest"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://downloads.php.net/~windows/releases/archives/php-$version-nts-Win32-vs16-x64.zip"
      },
      "32bit": {
        "url": "https://downloads.php.net/~windows/releases/archives/php-$version-nts-Win32-vs16-x86.zip"
      }
    },
    "hash": {
      "url": "https://www.php.net/backend/win-releases.json",
      "jsonpath": "$..[?(@.path == '$basename')].sha256"
    }
  }
}
