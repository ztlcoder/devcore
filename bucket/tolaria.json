{
    "version": "2026.4.28",
    "description": "Tolaria 是一款为 AI 时代设计的开源 Markdown 知识库管理工具，内置 MCP 服务。",
    "homepage": "https://tolaria.md/",
    "license": "AGPL-3.0",
    "url": "https://github.com/refactoringhq/tolaria/releases/download/stable-v2026.4.28/Tolaria_2026.4.28_x64-setup.exe",
    "hash": "E2BE25411C93B0AB740287F8C7C4AC3E617F10E8DE32DA4119C2D35173409419",
    "installer": {
        "args": [
            "/S",
            "/D=$dir"
        ]
    },
    "uninstaller": {
        "script": [
            "if (Test-Path \"$dir\\Uninstall.exe\") { Start-Process \"$dir\\Uninstall.exe\" -ArgumentList '/S' -Wait }",
            "$appData = [Environment]::GetFolderPath('ApplicationData')",
            "$localAppData = [Environment]::GetFolderPath('LocalApplicationData')",
            "$paths = @(\"$appData\\tolaria\", \"$localAppData\\tolaria\", \"$localAppData\\com.refactoringhq.tolaria\", \"$localAppData\\Tolaria\")",
            "foreach ($path in $paths) { if (Test-Path $path) { Remove-Item -Recurse -Force $path -ErrorAction SilentlyContinue } }",
            "Remove-Item -Path \"HKCU:\\Software\\tolaria\" -Recurse -ErrorAction SilentlyContinue"
        ]
    },
    "bin": "Tolaria.exe",
    "shortcuts": [
        [
            "Tolaria.exe",
            "Tolaria"
        ]
    ],
    "checkver": {
        "github": "https://github.com/refactoringhq/tolaria",
        "regex": "stable-v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/refactoringhq/tolaria/releases/download/stable-v$version/Tolaria_$version_x64-setup.exe"
    }
}