{
    "version": "8.4.20",
    "description": "A popular general-purpose scripting language that is especially suited to web development. (non-thread safe)",
    "homepage": "https://www.php.net/",
    "license": "PHP-3.01",
    "suggest":
    {
        "vcredist": "extras/vcredist2022"
    },
    "architecture":
    {
        "64bit":
        {
            "url": "https://downloads.php.net/~windows/releases/archives/php-8.4.20-nts-Win32-vs17-x64.zip",
            "hash": "bac1a970a676e8d875d5d39fc5ff388f231fadb9fb051b77b17db06a657673df"
        },
        "32bit":
        {
            "url": "https://downloads.php.net/~windows/releases/archives/php-8.4.20-nts-Win32-vs17-x86.zip",
            "hash": "cf202f45dcf7776d8ab2aafe3dd518bb0b3b5d8ccd2d84a9049aa0c5e7af8b66"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$dir\\php.ini\")) { Copy-Item \"$dir\\php.ini-development\" \"$dir\\php.ini\" }"
    ],
    "post_install": [
        "(Get-Content \"$dir\\php.ini\") | % { $_ -replace ';\\s?(extension_dir = \"ext\")', '$1' } | Set-Content \"$dir\\php.ini\""
    ],
    "bin":
    [
        "php.exe",
        "php-cgi.exe",
        "phpdbg.exe"
    ],
    "persist":
    [
        "ext",
        "php.ini"
    ],
    "checkver":
    {
        "url": "https://www.php.net/releases/branches.php",
        "jsonpath": "$..[?(@.version == '8.4')].latest"
    },
    "autoupdate":
    {
        "architecture":
        {
            "64bit":
            {
                "url": "https://downloads.php.net/~windows/releases/archives/php-$version-nts-Win32-vs17-x64.zip"
            },
            "32bit":
            {
                "url": "https://downloads.php.net/~windows/releases/archives/php-$version-nts-Win32-vs17-x86.zip"
            }
        },
        "hash":
        {
            "url": "https://www.php.net/backend/win-releases.json",
            "jsonpath": "$..[?(@.path == '$basename')].sha256"
        }
    }
}