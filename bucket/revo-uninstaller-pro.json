{
    "version": "5.4.7",
    "description": "Powerful software uninstaller with advanced leftover scanning.",
    "homepage": "https://www.revouninstaller.com/",
    "license": "Shareware",
    "url": "https://download.revouninstaller.com/download/RevoUninProSetup.exe",
    "hash": "6552AE17F3A024D74DB56B083B91895D780EDE60423EACDB578A03103EDFFC21",
    "innosetup": true,
    "pre_install": [
        "# 1. 修复所有带逗号后缀的文件名 (含 .exe, .dll, .lic)",
        "Get-ChildItem \"$dir\" -Recurse | Where-Object { $_.Name -match ',\\d+\\.' } | ForEach-Object {",
        "    $newName = $_.Name -replace ',\\d+', ''",
        "    $target = Join-Path $_.DirectoryName $newName",
        "    if (!(Test-Path $target)) { Move-Item $_.FullName $target -Force }",
        "}",
        "",
        "# 2. 移动核心程序文件",
        "if (Test-Path \"$dir\\{app}\") {",
        "    Move-Item \"$dir\\{app}\\*\" \"$dir\" -Force",
        "    Remove-Item \"$dir\\{app}\" -Force -Recurse",
        "}",
        "",
        "# 3. 提取授权文件并重命名为标准名称",
        "if (Test-Path \"$dir\\{commonappdata}\") {",
        "    $licFile = Get-ChildItem \"$dir\\{commonappdata}\" -Recurse -Filter \"*.lic\" | Select-Object -First 1",
        "    if ($licFile) { Move-Item $licFile.FullName \"$dir\\revouninstallerpro5.lic\" -Force }",
        "    Remove-Item \"$dir\\{commonappdata}\" -Force -Recurse",
        "}",
        "Get-ChildItem \"$dir\" -Include '{*}' -Directory | Remove-Item -Force -Recurse"
    ],
    "installer": {
        "script": [
            "# 准备持久化目录结构",
            "$revoPersist = \"$persist_dir\\Revo Uninstaller Pro\"",
            "if (!(Test-Path $revoPersist)) { New-Item $revoPersist -ItemType Directory -Force | Out-Null }",
            "",
            "# 将修复后的授权文件放入持久化目录",
            "if (Test-Path \"$dir\\revouninstallerpro5.lic\") {",
            "    Move-Item \"$dir\\revouninstallerpro5.lic\" \"$revoPersist\\revouninstallerpro5.lic\" -Force",
            "}",
            "",
            "# 建立 Junction 链接到 %ProgramData% (Revo 必须在 C 盘该位置看到授权)",
            "$commonData = \"$env:ProgramData\\VS Revo Group\"",
            "if (Test-Path $commonData) {",
            "    $item = Get-Item $commonData",
            "    if ($item.LinkType -ne 'Junction') { Remove-Item $commonData -Force -Recurse }",
            "}",
            "if (!(Test-Path $commonData)) {",
            "    New-Item -Path $commonData -ItemType Junction -Target \"$persist_dir\" -Force | Out-Null",
            "}"
        ]
    },
    "bin": "RevoUninPro.exe",
    "shortcuts": [
        [
            "RevoUninPro.exe",
            "Revo Uninstaller Pro"
        ]
    ],
    "persist": "Data",
    "elevate": true,
    "checkver": {
        "url": "https://revouninstaller.com",
        "re": "Version ([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://download.revouninstaller.com/download/RevoUninProSetup.exe"
    }
}
