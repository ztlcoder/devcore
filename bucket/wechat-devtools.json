    "persist": "wechat-devtools",
    "installer": {
        "script": [
            "Expand-7zipArchive \"$dir\\installer.exe\" \"$dir\\app\" -Removal",
            "@('$PLUGINSDIR', '卸载微信开发者工具.exe.nsis') | ForEach-Object {",
            "    Remove-Item \"$dir\\app\\$_\" -Recurse -Force",
            "}",
            "if (!(Test-Path \"$persist_dir\")) { New-Item \"$persist_dir\" -ItemType Directory | Out-Null }",
            "$appdata_path = \"$env:APPDATA\\微信开发者工具\"",
            "if (Test-Path $appdata_path) { if (!((Get-Item $appdata_path).Attributes -match 'ReparsePoint')) { Copy-Item \"$appdata_path\\*\" \"$persist_dir\" -Recurse -Force; Remove-Item $appdata_path -Recurse -Force } }",
            "New-Item -ItemType Junction -Path $appdata_path -Target \"$persist_dir\" -Force | Out-Null"
        ]
    },
    "uninstaller": {
        "script": "Remove-Item \"$env:APPDATA\\微信开发者工具\" -Force -Recurse"
    },
    "shortcuts": [
        [
            "app\\微信开发者工具.exe",
            "微信开发者工具"
        ]
    ],
    "checkver": {
        "url": "https://developers.weixin.qq.com/miniprogram/dev/devtools/stable.html",
        "regex": "#</a> ([\\d.]+) <a href=\"https://.*?Windows"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://servicewechat.com/wxa-dev-logic/download_redirect?type=win32_x64&from=mpwiki&download_version=$majorVersion$minorVersion$patchVersion$buildVersion&version_type=1#/installer.exe"
            },
            "32bit": {
                "url": "https://servicewechat.com/wxa-dev-logic/download_redirect?type=win32_ia32&from=mpwiki&download_version=$majorVersion$minorVersion$patchVersion$buildVersion&version_type=1#/installer.exe"
            }
        }
    },
    "notes": "User data is persisted in the 'wechat-devtools' folder and symlinked to %APPDATA%."
